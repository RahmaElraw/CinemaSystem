@using CinemaSystem.ViewModels


@model MovieWithRelatedVM

<!-- Service Start -->
    <div class="container-fluid service pt-6 pb-6">
        <div class="container">
            <div class="text-center mx-auto wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
            <h1 class="display-6 text-uppercase mb-5">Where Reliable Quality Meets Cinema Excellence 🎬</h1>
            </div>
            <div class="row g-4">

                @foreach(var item in Model.Movies)
                {
                     <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="service-item">
                        <div class="service-inner pb-5">
                            <img class="img-fluid w-100" src="~/images/cinema/service-@(item.Id).jpg" alt="">
                            <div class="service-text px-5 pt-4">
                                <h5 class="text-uppercase">@item.Name</h5>
                                    <p>@item.Description</p>
                            </div>
                            <a class="btn btn-light px-3" href="#">
                                Read More
                                <i class="bi bi-chevron-double-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
                }
               
                
            </div>
        </div>


    <div class="d-flex justify-content-center mt-3">
        <nav aria-label="Page navigation">
            <ul class="pagination">
               
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="/Home/Details?page=@(Model.CurrentPage - 1)">Previous</a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <li class="page-item active">
                            <a class="page-link" href="/Home/Details?page=@i">@i</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Home/Details?page=@i">@i</a>
                        </li>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="/Home/Details?page=@(Model.CurrentPage + 1)">Next</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
    </div>
    <!-- Service End -->
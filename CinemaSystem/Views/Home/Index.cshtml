    @* start dashboard *@

    <div class="container mt-5" id="dashboard">
    <h2 class="mb-4">🎬 Cinema Dashboard</h2>

    <div class="row">
        <!-- Movies -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-primary shadow">
                <div class="card-body text-center">
                    <h1 class="display-4">@ViewBag.MoviesCount</h1>
                    <p class="card-text fs-5">🎬 Movies</p>
                    <a href="/Movie/Index" class="btn btn-light btn-sm">View All</a>
                </div>
            </div>
        </div>

        <!-- Actors -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-success shadow">
                <div class="card-body text-center">
                    <h1 class="display-4">@ViewBag.ActorsCount</h1>
                    <p class="card-text fs-5">🎭 Actors</p>
                    <a href="/Actor/Index" class="btn btn-light btn-sm">View All</a>
                </div>
            </div>
        </div>

        <!-- Cinemas -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-warning shadow">
                <div class="card-body text-center">
                    <h1 class="display-4">@ViewBag.CinemasCount</h1>
                    <p class="card-text fs-5">🏛️ Cinemas</p>
                    <a href="/Cinema/Index" class="btn btn-light btn-sm">View All</a>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-danger shadow">
                <div class="card-body text-center">
                    <h1 class="display-4">@ViewBag.CategoriesCount</h1>
                    <p class="card-text fs-5">📁 Categories</p>
                    <a href="/Category/Index" class="btn btn-light btn-sm">View All</a>
                </div>
            </div>
        </div>
    </div>
</div>



@* end dashboard *@





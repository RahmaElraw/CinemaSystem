@model Movie

<div class="container mt-4">
    <h2>🗑️ Delete Movie</h2>

    <div class="card shadow-sm">
        <div class="row g-0">
            <div class="col-md-3">
                @if (Model.MainImg != null)
                {
                    <img src="~/images/movies/@Model.MainImg"
                         class="img-fluid rounded-start"
                         style="height:200px;object-fit:cover;width:100%" />
                }
            </div>
            <div class="col-md-9">
                <div class="card-body">
                    <h4 class="card-title">@Model.Name</h4>
                    <p class="text-muted">@Model.Description</p>
                    <p><strong>Category:</strong> @Model.Category?.Name</p>
                    <p><strong>Cinema:</strong> @Model.Cinema?.Name</p>
                    <p class="text-danger fw-bold">Are you going to permanently delete this movie along with all its images?</p>

                    <form asp-action="Delete" method="post">
                        <input asp-for="Id" type="hidden" />
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>